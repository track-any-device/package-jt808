{
    "name": "track-any-device/jt808",
    "description": "JT808 protocol driver, connector, and stream consumer for the Track Any Device platform.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^13.7"
    },
    "autoload": {
        "psr-4": {
            "TrackAnyDevice\\Jt808\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TrackAnyDevice\\Jt808\\Jt808ServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
